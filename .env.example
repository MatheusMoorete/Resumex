NODE_ENV=production
PORT=8787

# Authentication provider. Supabase is the current replaceable adapter.
AUTH_PROVIDER=supabase
VITE_AUTH_PROVIDER=supabase
AUTH_DEBUG=false
VITE_AUTH_DEBUG=false
# The publishable key is safe for browser use.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Comma-separated allowlist.
ALLOWED_EMAILS=matheus.moorete@gmail.com,jessouzaoliveira@gmail.com

# Server-side provider keys. Do not use VITE_ prefixes in production.
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=
OPENAI_API_KEY=
KIMI_API_KEY=
OPENROUTER_API_KEY=

# Optional model overrides for the optimized PDF pipeline.
ZHIPU_VISION_MODEL=glm-4.5v
KIMI_VISION_MODEL=kimi-k3
DEEPSEEK_SUMMARY_MODEL=deepseek-v4-pro

# Central model routing. Keep provider keys on the server in production.
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
DEEPSEEK_PRO_MODEL=deepseek-v4-pro
OPENAI_AUDIT_MODEL=gpt-5.6-terra
KIMI_AUDIT_MODEL=kimi-k3
OPENROUTER_AUDIT_MODEL=moonshotai/kimi-k3
OPENROUTER_CRITICAL_AUDIT_MODEL=openai/gpt-5.6-terra-pro
OPENROUTER_SITE_URL=https://resumex.app
OPENROUTER_APP_TITLE=ResumeX
AI_ENABLE_GPT_AUDITOR=false
# openrouter, kimi or openai. Falls back across configured independent auditors.
AI_PRIMARY_AUDITOR=openrouter

# Notion export. Create an internal integration and share the parent page with it.
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=
NOTION_API_VERSION=2022-06-28

# Notion OAuth. Use this for per-user Notion connections.
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=https://resumex-gamma.vercel.app/api/notion/oauth/callback

# Local E2E mock. Only works in Vite dev on localhost and non-production local API requests.
VITE_E2E_MOCK=false
E2E_MOCK_AUTH=false
E2E_NOTION_MOCK=false

# Optional. Large summaries and visual transcription can take time.
AI_UPSTREAM_TIMEOUT_MS=600000
