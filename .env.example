NODE_ENV=production
PORT=8787

# Authentication provider. Supabase is the current replaceable adapter.
AUTH_PROVIDER=supabase
VITE_AUTH_PROVIDER=supabase
# The publishable key is safe for browser use.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Comma-separated allowlist.
ALLOWED_EMAILS=matheus.moorete@gmail.com,jessouzaoliveira@gmail.com

# Server-side provider keys. Do not use VITE_ prefixes in production.
DEEPSEEK_API_KEY=
ZHIPU_API_KEY=

# Notion export. Create an internal integration and share the parent page with it.
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=
NOTION_API_VERSION=2022-06-28

# Notion OAuth. Use this for per-user Notion connections.
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=https://resumex-gamma.vercel.app/api/notion/oauth/callback

# Local E2E mock. Only works in Vite dev on localhost and non-production local API requests.
VITE_E2E_MOCK=false
E2E_MOCK_AUTH=false
E2E_NOTION_MOCK=false

# Optional. Large summaries and visual transcription can take time.
AI_UPSTREAM_TIMEOUT_MS=600000
