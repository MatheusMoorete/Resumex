# Public hostname. Use :80 for a local HTTP-only test.
APP_DOMAIN=app.example.com

NODE_ENV=production
PORT=10000

AUTH_PROVIDER=supabase
VITE_AUTH_PROVIDER=supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

ALLOWED_EMAILS=you@example.com

DEEPSEEK_API_KEY=
ZHIPU_API_KEY=
KIMI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

ZHIPU_VISION_MODEL=glm-4.5v
KIMI_VISION_MODEL=kimi-k3
DEEPSEEK_SUMMARY_MODEL=deepseek-v4-pro

NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=https://app.example.com/api/notion/oauth/callback

AI_UPSTREAM_TIMEOUT_MS=600000
